# --- Database (PostgreSQL container) ---
DATABASE_URL=postgres://bbr:bbr@localhost:5432/bbr
POSTGRES_USER=bbr
POSTGRES_PASSWORD=bbr
POSTGRES_DB=bbr

# --- Redis (queue + cache) ---
REDIS_URL=redis://localhost:6379

# --- App ---
NODE_ENV=development
APP_URL=http://localhost:3000

# --- RankedIn parsing (stage import source) ---
RANKEDIN_BASE_URL=https://rankedin.com

# --- Admin auth (single admin; bcrypt hash, not plaintext. The session cookie
#     is signed with a key derived from username+hash — no separate secret) ---
# Generate the hash:
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1],10))" '<password>'
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$10$replace-with-a-real-bcrypt-hash

# --- Deployment (used only by the production docker-compose.yml on the server) ---
# Image is ghcr.io/<GITHUB_REPOSITORY>:<IMAGE_TAG>
GITHUB_REPOSITORY=polnikov/spb-squash-statistic
IMAGE_TAG=latest
# External docker network shared with the host Caddy container (it proxies to
# bbr-app:3000 by name). Set to the real Caddy network name on the server.
CADDY_NETWORK=caddy
# In prod set APP_URL to the public domain:
# APP_URL=https://bbrsquashspb.ohmyapps.xyz
